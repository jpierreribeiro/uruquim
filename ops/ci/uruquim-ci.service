[Unit]
Description=Uruquim clean verification gate
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=uruquim-ci
Group=uruquim-ci
EnvironmentFile=-/etc/uruquim-ci.env
ExecStart=/opt/uruquim-ci/run.sh
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/opt/uruquim-ci /var/lib/uruquim-ci
